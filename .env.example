# Fix for macOS ARM: limit threads to prevent sklearn/OpenBLAS crashes / segfaults
# Copy this file to .env and adjust if needed. Apply before numpy loads (see run_autointent.py).
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1
NUMEXPR_NUM_THREADS=1
LOKY_MAX_CPU_COUNT=1
TOKENIZERS_PARALLELISM=false
